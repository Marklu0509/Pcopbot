{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "1": { "text": "UP" }, "0": { "text": "DOWN" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Bot Alive (last poll < 60s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "(time() - pcopbot_last_poll_timestamp_seconds) < 60",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Active Traders",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "pcopbot_active_traders", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Poll Duration (p95)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.95, rate(pcopbot_poll_duration_seconds_bucket[5m]))", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Fill Buffer Size",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "pcopbot_fill_buffer_size", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 1, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "title": "Trades by Status (rate / 5m)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum by (status) (rate(pcopbot_trades_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cumulative Trades by Side",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum by (side) (pcopbot_trades_total)", "legendFormat": "{{side}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Poll Duration over Time (p50 / p95)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.50, rate(pcopbot_poll_duration_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.95, rate(pcopbot_poll_duration_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "B" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pcopbot"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Pcopbot Overview",
  "uid": "pcopbot-overview",
  "version": 1
}
